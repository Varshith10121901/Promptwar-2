{
  "name": "votewise",
  "version": "2.1.0",
  "description": "VoteWise — AI-Powered Personal Election Assistant using Google Cloud Services",
  "author": "VoteWise Team",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint js/ --ext .js",
    "lint:fix": "eslint js/ --ext .js --fix",
    "format": "prettier --write \"js/**/*.js\" \"css/**/*.css\" \"*.html\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.27.0",
    "globals": "^17.6.0",
    "husky": "^9.1.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
}

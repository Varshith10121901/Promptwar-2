{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "globals": {
    "firebase": "readonly",
    "gtag": "readonly",
    "lucide": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "warn",
    "no-undef": "error",
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "curly": "error"
  }
}
